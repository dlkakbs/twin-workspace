# Twin Workspace Backend
# Copy this file to backend/.env and update the values for your machine.

# Hermes API server URL (used to verify the login token)
HERMES_API_SERVER_URL=http://localhost:8642

# Hermes paths
# In the single-repo layout, HERMES_ROOT defaults to ../hermes-agent relative to backend/.
# You only need to override these if you move the Hermes subtree elsewhere.
HERMES_ROOT=../hermes-agent
HERMES_OUTPUTS=../hermes-agent/outputs/twin
TWIN_OUTPUT_ROOT=../hermes-agent/outputs/twin

# Default twin profile slug
TWIN_PROFILE_SLUG=my-twin
TWIN_SUMMARY_LANGUAGE=en
