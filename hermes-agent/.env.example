# Twin / Hermes environment
# Copy to hermes-agent/.env and fill in the providers you actually use.

TWIN_PROFILE_SLUG=my-twin
TWIN_OUTPUT_ROOT=./outputs/twin

# LLMs
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# ElevenLabs / telephony
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_AGENT_ID=
ELEVENLABS_PHONE_NUMBER_ID=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TWIN_SUMMARY_LANGUAGE=en

# Video / avatar
HEYGEN_API_KEY=
HEYGEN_AVATAR_ID=
HEYGEN_VOICE_ID=
LIVEAVATAR_API_KEY=
LIVEAVATAR_AVATAR_ID=

# Realtime
DEEPGRAM_API_KEY=
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
TWIN_PUBLIC_BASE_URL=
